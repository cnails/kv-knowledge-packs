% neurips_2024.sty - Simplified NeurIPS style
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/01/01 NeurIPS 2024 style (simplified)]

\DeclareOption{preprint}{\newcommand{\neuripspreprint}{}}
\DeclareOption{final}{}
\DeclareOption{nonatbib}{}
\ProcessOptions\relax

\RequirePackage{natbib}
\RequirePackage{geometry}
\geometry{
  textheight=9in,
  textwidth=5.5in,
  top=1in,
  headheight=12pt,
  headsep=25pt,
  footskip=30pt
}

\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhead{}
\fancyfoot{}
\fancyfoot[C]{\thepage}
\renewcommand{\headrulewidth}{0pt}

% Title formatting
\renewcommand{\maketitle}{%
  \begin{center}%
    {\LARGE\bfseries \@title \par}%
    \vskip 0.5em%
    {\large \@author \par}%
    \vskip 1em%
  \end{center}%
}

\setlength{\parindent}{0pt}
\setlength{\parskip}{6pt}
